{
  "name": "video-workflow",
  "version": "1.0.0",
  "description": "视频创作工作流桌面应用",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "echarts": "^6.0.0",
    "express": "^4.18.2",
    "fluent-ffmpeg": "^2.1.3",
    "playwright": "^1.58.2",
    "puppeteer-core": "^24.39.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.videoworkflow.app",
    "productName": "视频创作工作流",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "shared/**/*",
      "scripts/**/*",
      "jimeng/**/*",
      "kling/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "视频创作工作流"
    }
  }
}
